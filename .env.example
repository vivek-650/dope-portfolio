# Umami analytics
# Example for Umami Cloud: https://cloud.umami.is/script.js
# Example for self-hosted: https://analytics.yourdomain.com/script.js
NEXT_PUBLIC_UMAMI_SCRIPT_URL=

# Website ID from Umami dashboard -> Settings -> Website ID
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Optional: comma-separated domains (recommended in production)
# Example: yourdomain.com,www.yourdomain.com
NEXT_PUBLIC_UMAMI_DOMAINS=
