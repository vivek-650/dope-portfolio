# Umami analytics
# Example for Umami Cloud: https://cloud.umami.is/script.js
# Example for self-hosted: https://analytics.yourdomain.com/script.js
NEXT_PUBLIC_UMAMI_SCRIPT_URL=

# Website ID from Umami dashboard -> Settings -> Website ID
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Optional: comma-separated domains (recommended in production)
# Example: yourdomain.com,www.yourdomain.com
NEXT_PUBLIC_UMAMI_DOMAINS=

# Umami Admin API (needed to show lifetime visitor count in footer)
# Base URL for Umami API. If omitted, it is derived from NEXT_PUBLIC_UMAMI_SCRIPT_URL.
# Example: https://cloud.umami.is
UMAMI_API_URL=

# Choose one auth method for Umami API access:
# 1) API key (recommended)
UMAMI_API_KEY=

# 2) Bearer token
UMAMI_BEARER_TOKEN=

# 3) Username/password (fallback login flow)
UMAMI_USERNAME=
UMAMI_PASSWORD=

# Neon PostgreSQL
# Example: postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=
